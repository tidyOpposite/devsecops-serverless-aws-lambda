# CLI-owned generated file. Do not edit directly.
# Update .devsecops-pipeline.toml and rerun `devsecops render`.
# See docs/generated-artifacts.md for ownership rules.

project_name              = "golden-pipeline"
aws_region                = "eu-central-1"
lambda_image_uri          = "123456789012.dkr.ecr.eu-central-1.amazonaws.com/golden-pipeline:sha-abc123"
api_authorization_type    = "AWS_IAM"
terraform_admin_role_name = "golden-terraform-admin"

environment_config = {
  dev = {
    lambda_memory_size         = 1024
    lambda_timeout             = 120
    log_retention_days         = 30
    api_throttling_burst_limit = 25
    api_throttling_rate_limit  = 50
    cors_allowed_origins       = ["https://dev.example.com"]
  }
  staging = {
    lambda_memory_size         = 1536
    lambda_timeout             = 180
    log_retention_days         = 90
    api_throttling_burst_limit = 50
    api_throttling_rate_limit  = 100
    cors_allowed_origins       = ["https://staging.example.com"]
  }
  prod = {
    lambda_memory_size         = 2048
    lambda_timeout             = 300
    log_retention_days         = 365
    api_throttling_burst_limit = 50
    api_throttling_rate_limit  = 100
    cors_allowed_origins       = ["https://app.example.com"]
  }
}
